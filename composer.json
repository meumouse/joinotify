{
    "name": "meumouse/joinotify",
    "description": "Aumente a satisfação do seu cliente automatizando o envio de mensagens via WhatsApp com o Joinotify.",
    "type": "wordpress-plugin",
    "license": "Proprietary",
    "authors": [
        {
            "name": "MeuMouse.com",
            "email": "contato@meumouse.com",
            "homepage": "https://meumouse.com"
        }
    ],
    "require": {
        "php": ">= 7.4",
        "giggsey/libphonenumber-for-php": "^8.13"
    },
    "autoload": {
        "psr-4": {
            "MeuMouse\\Joinotify\\": "inc/"
        }
    },
    "scripts": {
        "build-linux": [
            "rm -rf build joinotify.zip",
            "mkdir -p build/joinotify",
            "rsync -av --exclude=dist --exclude=composer.json --exclude=composer.lock ./ build/joinotify/",
            "cd build && zip -r ../joinotify.zip joinotify",
            "rm -rf build"
        ],
        "build-windows": [
            "powershell -Command \"if (Test-Path 'build') { Remove-Item -Recurse -Force build }\"",
            "powershell -Command \"if (Test-Path 'joinotify.zip') { Remove-Item -Force joinotify.zip }\"",
            "powershell -Command \"New-Item -ItemType Directory -Path build\\joinotify | Out-Null\"",
            "powershell -Command \"Get-ChildItem -Path . -Exclude dist,composer.json,composer.lock,build | Copy-Item -Destination build\\joinotify -Recurse -Force\"",
            "powershell -Command \"Compress-Archive -Path build\\joinotify -DestinationPath joinotify.zip\"",
            "powershell -Command \"Remove-Item -Recurse -Force build\""
        ]
    }
}