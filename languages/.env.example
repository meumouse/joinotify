# Google Cloud Translation API key (engine: google, the default)
GOOGLE_TRANSLATE_API_KEY=AIzaSyC8u...

# OpenAI API key (engine: openai, AI-powered translation)
OPENAI_API_KEY=sk-...
# Optional overrides for the OpenAI engine
OPENAI_MODEL=gpt-4o-mini
